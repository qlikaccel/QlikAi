              }
            ]
          },
          {
            "name": "treatment_duration_days",
            "dataType": "string",
            "sourceColumn": "treatment_duration_days",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "name": "severity_level",
            "dataType": "string",
            "sourceColumn": "severity_level",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "name": "is_contagious",
            "dataType": "string",
            "sourceColumn": "is_contagious",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
