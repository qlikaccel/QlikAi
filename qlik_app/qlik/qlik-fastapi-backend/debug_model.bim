              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "Employees-Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    SiteUrl = \"https://sorimtechnologies.sharepoint.com\",",
                "    Source = SharePoint.Files(SiteUrl, [ApiVersion = 15]),",
                "    Filtered = Table.SelectRows(",
                "        Source,",
                "        each",
                "            Text.EndsWith(Text.Lower([Name]), \"dim_employee.csv\") and",
                "            Text.Contains(Text.Lower([Folder Path]), \"shared documents\")",
                "    ),",
                "    File = if Table.RowCount(Filtered) > 0",
                "        then Filtered{0}[Content]",
                "        else error \"File dim_employee.csv not found in SharePoint\",",
                "    Csv = Csv.Document(File, [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Headers = Table.PromoteHeaders(Csv, [PromoteAllScalars=true]),",
                "    DeptMapFile = Table.SelectRows(",
                "        Source,",
                "        each Text.EndsWith(Text.Lower([Name]), \"dim_department.csv\")",
                "    ){0}[Content],",
                "    DeptMapCsv = Csv.Document(",
                "        DeptMapFile,",
                "        [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]",
                "    ),",
                "    DeptMapHeaders = Table.PromoteHeaders(",
                "        DeptMapCsv,",
                "        [PromoteAllScalars=true]",
                "    ),",
                "    TypedTable = Table.TransformColumnTypes(",
                "        Headers,",
                "        {",
                "        {\"employee_id\", type text},",
                "        {\"department_id\", type text},",
                "        {\"role_id\", type text},",
                "        {\"location_id\", type text},",
                "        {\"salary_band_id\", type text}",
                "        }",
                "    ),",
                "    #\"NestedJoin_DeptMap\" = Table.NestedJoin(",
                "        TypedTable,",
                "        {\"department_id\"},",
                "        DeptMapHeaders,",
                "        {\"department_id\"},",
                "        \"DeptMap_joined\",",
                "        JoinKind.LeftOuter",
                "    ),",
                "    #\"Expand_DeptMap\" = Table.ExpandTableColumn(",
                "        #\"NestedJoin_DeptMap\",",
                "        \"DeptMap_joined\",",
                "        {\"emp_department_name\"},",
                "        {\"emp_department_name\"}",
                "    ),",
                "    #\"ReplaceNulls_DeptMap\" = Table.ReplaceValue(",
                "        #\"Expand_DeptMap\",",
                "        null,",
                "        \"Unknown\",",
                "        Replacer.ReplaceValue,",
                "        {\"emp_department_name\"}",
                "    )",
                "in",
                "    #\"ReplaceNulls_DeptMap\""
              ]
            }
          }
        ]
      },
