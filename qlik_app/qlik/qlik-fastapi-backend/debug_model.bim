        "partitions": [
          {
            "name": "Final_Activity-Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    SiteUrl = \"https://sorimtechnologies.sharepoint.com\",",
                "    Source = SharePoint.Files(SiteUrl, [ApiVersion = 15]),",
                "    Filtered = Table.SelectRows(",
                "        Source,",
                "        each",
                "            Text.EndsWith(Text.Lower([Name]), \"fact_employee_activity_1m.csv\") and",
                "            Text.Contains(Text.Lower([Folder Path]), \"shared documents\")",
                "    ),",
                "    File = if Table.RowCount(Filtered) > 0",
                "        then Filtered{0}[Content]",
                "        else error \"File fact_employee_activity_1M.csv not found in SharePoint\",",
                "    Csv = Csv.Document(File, [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    Headers = Table.PromoteHeaders(Csv, [PromoteAllScalars=true]),",
                "    Add_work_type = Table.AddColumn(",
                "        Headers,",
                "        \"work_type\",",
                "        each if [hours_worked] > 8 then \"Overtime\" else \"Normal\",",
                "        Int64.Type",
                "    ),",
                "    Add_productivity_flag = Table.AddColumn(",
                "        Add_work_type,",
                "        \"productivity_flag\",",
                "        each if [hours_worked] >= 8 then 1 else 0,",
                "        Int64.Type",
                "    ),",
                "    Add_productivity_score = Table.AddColumn(",
                "        Add_productivity_flag,",
                "        \"productivity_score\",",
                "        each [hours_worked] * 10,",
                "        Int64.Type",
                "    )",
                "in",
                "    Add_productivity_score"
              ]
            }
          }
        ]
      }
