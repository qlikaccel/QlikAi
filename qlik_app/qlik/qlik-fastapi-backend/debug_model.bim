        "partitions": [
          {
            "name": "RawSalesOrders-Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    SiteUrl = \"https://sorimtechnologies.sharepoint.com\",",
                "    FileName = \"SalesOrders.csv\",",
                "    Source = SharePoint.Files(SiteUrl, [ApiVersion = 15]),",
                "    FilteredByName = Table.SelectRows(",
                "        Source,",
                "        each Text.Lower([Name]) = Text.Lower(FileName)",
                "    ),",
                "    FilteredByLib = if Table.RowCount(FilteredByName) > 1",
                "        then Table.SelectRows(FilteredByName, each Text.Contains([Folder Path], \"Shared Documents\"))",
                "        else FilteredByName,",
                "    FileBinary = if Table.RowCount(FilteredByLib) = 0",
                "        then error \"File \" & FileName & \" not found under \" & SiteUrl &",
                "             \". Ensure the file exists in SharePoint and credentials are set.\"",
                "        else FilteredByLib{0}[Content],",
                "    CsvData = Csv.Document(",
                "        FileBinary,",
                "        [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]",
                "    ),",
                "    PromotedHeaders = Table.PromoteHeaders(CsvData, [PromoteAllScalars=true]),",
                "    TypedTable = Table.TransformColumnTypes(",
                "        PromotedHeaders,",
                "        {",
                "        {\"TransactionID\", type text},",
                "        {\"CustomerID\", type text},",
                "        {\"ProductID\", type text},",
                "        {\"SalesRepID\", type text},",
                "        {\"Quantity\", Int64.Type},",
                "        {\"UnitPrice\", type number},",
                "        {\"Discount\", Int64.Type},",
                "        {\"Revenue\", type number},",
                "        {\"Status\", type text},",
                "        {\"Channel\", type text},",
                "        {\"Year\", Int64.Type},",
                "        {\"Month\", Int64.Type},",
                "        {\"MonthName\", type text},",
                "        {\"Quarter\", type text}",
                "        }",
                "    )",
                "in",
                "    TypedTable"
              ]
            }
          }
        ]
      },
