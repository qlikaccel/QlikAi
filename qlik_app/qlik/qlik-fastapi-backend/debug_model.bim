        "partitions": [
          {
            "name": "Treatment_Master-Partition",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    SiteUrl = \"https://sorimtechnologies.sharepoint.com\",",
                "    FileName = \"Treatment_Master.csv\",",
                "    Source = SharePoint.Files(SiteUrl, [ApiVersion = 15]),",
                "    FilteredByName = Table.SelectRows(",
                "        Source,",
                "        each Text.Lower([Name]) = Text.Lower(FileName)",
                "    ),",
                "    FilteredByLib = if Table.RowCount(FilteredByName) > 1",
                "        then Table.SelectRows(FilteredByName, each Text.Contains([Folder Path], \"Shared Documents\"))",
                "        else FilteredByName,",
                "    FileBinary = if Table.RowCount(FilteredByLib) = 0",
                "        then error \"File \" & FileName & \" not found under \" & SiteUrl &",
                "             \". Ensure the file exists in SharePoint and credentials are set.\"",
                "        else FilteredByLib{0}[Content],",
                "    CsvData = Csv.Document(",
                "        FileBinary,",
                "        [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]",
                "    ),",
                "    PromotedHeaders = Table.PromoteHeaders(CsvData, [PromoteAllScalars=true]),",
                "    TypedTable = Table.TransformColumnTypes(",
                "        PromotedHeaders,",
                "        {",
                "        {\"treatment_id\", type text},",
                "        {\"patient_id\", type text},",
                "        {\"doctor_id\", type text},",
                "        {\"disease_id\", type text},",
                "        {\"patient_name\", type text},",
                "        {\"patient_age\", Int64.Type},",
                "        {\"patient_gender\", type text},",
                "        {\"patient_city\", type text},",
                "        {\"patient_blood_group\", type text},",
                "        {\"patient_occupation\", type text},",
                "        {\"doctor_name\", type text},",
                "        {\"doctor_type\", type text},",
                "        {\"doctor_specialization\", type text},",
                "        {\"doctor_experience_years\", Int64.Type},",
                "        {\"doctor_qualification\", type text},",
                "        {\"hospital_name\", type text},",
                "        {\"hospital_city\", type text},",
                "        {\"disease_name\", type text},",
                "        {\"disease_category\", type text},",
                "        {\"disease_type\", type text},",
                "        {\"disease_severity\", type text},",
                "        {\"is_contagious\", type logical},",
                "        {\"treatment_start_date\", type date},",
                "        {\"treatment_end_date\", type date},",
                "        {\"treatment_duration_days\", Int64.Type},",
                "        {\"admission_mode\", type text},",
                "        {\"room_type\", type text},",
                "        {\"prescription_type\", type text},",
                "        {\"medication_prescribed\", type text},",
                "        {\"dosage\", Int64.Type},",
                "        {\"tests_conducted\", type text},",
                "        {\"diet_plan\", type text},",
                "        {\"attending_nurse\", type text},",
                "        {\"follow_up_required\", type text},",
                "        {\"complications\", type text},",
                "        {\"total_treatment_cost\", type number},",
                "        {\"consultation_fee\", type number},",
                "        {\"insurance_provider\", type text},",
                "        {\"insurance_claimed\", type text},",
                "        {\"insurance_amount_covered\", type number},",
                "        {\"out_of_pocket_expense\", type number},",
                "        {\"payment_method\", type text},",
                "        {\"treatment_status\", type text},",
                "        {\"outcome\", type text},",
                "        {\"patient_satisfaction\", type text},",
                "        {\"readmission_risk\", type text},",
                "        {\"remarks\", type text}",
                "        }",
                "    )",
                "in",
                "    TypedTable"
              ]
            }
          }
        ]
      }
