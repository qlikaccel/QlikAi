            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    RawServiceTickets = RawServiceTickets,",
                "    Selected = Table.SelectColumns(RawServiceTickets,",
                "        {\"TransactionID\", \"TransactionDate\", \"CustomerID\", \"CustomerName\", \"CustomerSegment\", \"CustomerRegion\", \"ProductID\", \"ProductName\", \"Category\", \"SalesRepID\", \"SalesRepName\", \"SalesRepRegion\", \"Priority\", \"HoursLogged\", \"Revenue\", \"GrossProfit\", \"Status\", \"Channel\", \"Quantity\", \"UnitPrice\", \"Discount\", \"SalesRepAnnualQuota\", \"DealTier\", \"Year\", \"Month\", \"MonthName\", \"Quarter\", \"TransactionType\"}",
                "    ),",
                "    TypedTable = Table.TransformColumnTypes(",
                "        Selected,",
                "        {",
                "        {\"TransactionID\", type text},",
                "        {\"TransactionDate\", type date},",
                "        {\"CustomerID\", type text},",
                "        {\"CustomerName\", type text},",
                "        {\"CustomerSegment\", type text},",
                "        {\"CustomerRegion\", type text},",
                "        {\"ProductID\", type text},",
                "        {\"ProductName\", type text},",
                "        {\"Category\", type text},",
                "        {\"SalesRepID\", type text},",
                "        {\"SalesRepName\", type text},",
                "        {\"SalesRepRegion\", type text},",
                "        {\"Priority\", type text},",
                "        {\"HoursLogged\", type text},",
                "        {\"Revenue\", type number},",
                "        {\"GrossProfit\", type text},",
                "        {\"Status\", type text},",
                "        {\"Channel\", type text},",
                "        {\"Quantity\", type text},",
                "        {\"UnitPrice\", type text},",
                "        {\"Discount\", type text},",
                "        {\"SalesRepAnnualQuota\", type text},",
                "        {\"DealTier\", type text},",
                "        {\"Year\", Int64.Type},",
                "        {\"Month\", Int64.Type},",
                "        {\"MonthName\", type text},",
